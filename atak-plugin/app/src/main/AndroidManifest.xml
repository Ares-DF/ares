<?xml version="1.0" encoding="utf-8"?>
<!-- ARES-ATAK plugin manifest (skeleton). ATAK loads the plugin via the
     transapps Lifecycle/Tool classes declared in assets/plugin.xml; this
     manifest mostly declares permissions + the plugin api version meta-data. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ares.atak.plugin">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- coverage KMZ export goes to atak/ARES/KMZ/ (scoped storage / ATAK's dir) -->

    <application
        android:allowBackup="true"
        android:label="@string/app_name">

        <!-- ATAK plugin API version this build targets. MUST match the SDK. -->
        <meta-data android:name="plugin-api" android:value="@string/plugin_api" />

        <!-- The transapps plugin descriptor. -->
        <meta-data android:name="app_desc" android:value="@string/app_desc" />
    </application>
</manifest>
