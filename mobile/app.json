{
  "expo": {
    "name": "Ares",
    "slug": "ares",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ares.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to set transmitter location from your current GPS position"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "package": "com.ares.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": [
      ["expo-location", {
        "locationWhenInUsePermission": "Ares needs location to set transmitter position."
      }]
    ]
  }
}
